# App
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=integralservices
DATABASE_URL=mysql://root:root@localhost:3306/integralservices

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# JWT / Auth
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS (opcional, vacío = *)
# CORS_ORIGIN=https://app.example.com

# Logging
LOG_LEVEL=info

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs
