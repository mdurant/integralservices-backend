NODE_ENV=development
PORT=3000
TZ=America/Santiago

# App en tu máquina + MySQL en Docker: DB_HOST=localhost, DB_PORT=3307
# App dentro de Docker: DB_HOST=mysql, DB_PORT=3306
DB_HOST=localhost
DB_PORT=3307
DB_NAME=integralservices
DB_USER=app
DB_PASS=app

JWT_ACCESS_SECRET=change_me_access_2026
JWT_REFRESH_SECRET=change_me_refresh_2026
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=15

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

LOG_LEVEL=info

SWAGGER_TITLE=IntegralServices API
SWAGGER_VERSION=1.0.0
SWAGGER_BASE_PATH=/api/v1

# SMTP / Mailtrap (dev - correos de activación, OTP, recovery)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=de764e9395e75d
SMTP_PASS=
SMTP_FROM=Integral Services <noreply@integralservices.local>

# Auth (activación, OTP, 2FA) — Enlaces de correo apuntan al backend :3000
# Ej: http://localhost:3000/auth/activate?token=... y .../auth/reset-password?token=...
FRONTEND_URL=http://localhost:3000
# CORS: origen permitido para peticiones desde el navegador (opcional)
# CORS_ORIGIN=http://localhost:3000
OTP_TTL_MIN=10
ACTIVATION_TOKEN_TTL_HOURS=24
UPLOAD_DIR=uploads

# Worker
WORKER_EXPIRE_QUOTES_INTERVAL_SEC=60